{
  "name": "html-viewer",
  "version": "0.11.0",
  "description": "A macOS HTML and Markdown viewer launched from CLI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.zdennis.html-viewer",
    "productName": "HTML Viewer",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": false,
    "win": false,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon.png",
    "bin": {
      "html-viewer": "bin/html-viewer"
    }
  },
  "dependencies": {
    "electron": "^28.0.0",
    "electron-store": "^8.1.0",
    "github-markdown-css": "^5.9.0",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  }
}
